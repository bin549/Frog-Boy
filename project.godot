; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

[application]

config/name="frog-boy"
run/main_scene="res://scenes/UI/MainMenu.tscn"
boot_splash/image="res://icon.png"
boot_splash/fullsize=false
boot_splash/use_filter=false
boot_splash/bg_color=Color( 0.87451, 0.964706, 0.960784, 1 )
config/icon="res://icon.png"
config/windows_native_icon="res://icon.ico"

[autoload]

LevelManager="*res://scenes/LevelManager.tscn"
Helpers="*res://scripts/helpers.gd"
ScreenTransitionManager="*res://scenes/ScreenTransitionManager.tscn"
MouseCursor="*res://scenes/UI/MouseCursor.tscn"
MusicPlayer="*res://scenes/MusicPlayer.tscn"

[display]

window/size/width=480
window/size/height=270
window/size/test_width=1920
window/size/test_height=1080
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[input]

move_left={
"deadzone": 0.5,
"events": [ Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":0,"alt":false,"shift":false,"control":false,"meta":false,"command":false,"pressed":false,"scancode":16777231,"unicode":0,"echo":false,"script":null)
 ]
}
